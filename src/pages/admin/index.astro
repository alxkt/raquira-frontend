---
export const prerender = false; // Enable SSR for this page

import "../../styles/global.css";
import type { Photo } from "../../lib/photos";
import { parseSizes, formatAdminDate } from "../../lib/photos";

const runtime = (Astro.locals as any).runtime;
const ADMIN_PASSWORD = runtime?.env?.ADMIN_PASSWORD ?? import.meta.env.ADMIN_PASSWORD;

// Check if password is configured
if (!ADMIN_PASSWORD) {
    return new Response("Admin password not configured", { status: 500 });
}

// Check for auth token in cookie
const authToken = Astro.cookies.get("admin_auth")?.value;
const isAuthenticated = authToken === ADMIN_PASSWORD;

// If not authenticated, show login form
if (!isAuthenticated) {
    // Check if this is a login attempt
    if (Astro.request.method === "POST") {
        const formData = await Astro.request.formData();
        const password = formData.get("password");

        if (password === ADMIN_PASSWORD) {
            // Set auth cookie and redirect
            Astro.cookies.set("admin_auth", ADMIN_PASSWORD, {
                path: "/",
                httpOnly: true,
                secure: import.meta.env.PROD,
                sameSite: "strict",
                maxAge: 60 * 60 * 24 * 7, // 7 days
            });
            return Astro.redirect("/admin");
        }
    }
}

// Fetch photo data if authenticated
let photo: Photo | null = null;
let maxImageId = 0;
let error: string | null = null;

if (isAuthenticated) {
    const apiBase = import.meta.env.PUBLIC_USE_LOCAL_BACKEND === "true"
        ? "http://localhost:8080"
        : import.meta.env.PUBLIC_API_BASE_URL;

    const url = new URL(Astro.request.url);
    const photoId = parseInt(url.searchParams.get("id") || "1", 10);

    try {
        // Fetch stats to get max ID
        const statsRes = await fetch(`${apiBase}/images/stats`);
        if (!statsRes.ok) throw new Error(`Stats API returned ${statsRes.status}`);
        const stats = await statsRes.json();
        maxImageId = stats.maxImageId;

        // Fetch the specific photo
        const photoRes = await fetch(`${apiBase}/images/${photoId}`);
        if (!photoRes.ok) throw new Error(`Photo API returned ${photoRes.status}`);
        photo = await photoRes.json();
    } catch (e) {
        error = e instanceof Error ? e.message : "Failed to fetch photo";
    }
}

const imageBaseURL = import.meta.env.PUBLIC_IMAGE_BASE_URL;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <link
            rel="icon"
            type="image/png"
            sizes="16x16"
            href="/favicon-16.png"
        />
        <link
            rel="icon"
            type="image/png"
            sizes="24x24"
            href="/favicon-24.png"
        />
        <link
            rel="icon"
            type="image/png"
            sizes="32x32"
            href="/favicon-32.png"
        />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />
        <title>Admin | Raquira</title>
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap"
            rel="stylesheet"
        />
        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap"
            rel="stylesheet"
        />
    </head>
    <body
        class="bg-zinc-950 min-h-screen"
        style="font-family: 'Inter', sans-serif;"
    >
        {
            !isAuthenticated ? (
                <div class="flex items-center justify-center min-h-screen p-4">
                    <div class="w-full max-w-md">
                        <h1
                            class="text-red-50 text-3xl font-bold mb-8 text-center"
                            style="font-family: 'Poppins', sans-serif;"
                        >
                            Admin Login
                        </h1>
                        <form
                            method="POST"
                            class="bg-zinc-900 rounded-lg p-8 shadow-xl"
                        >
                            <div class="mb-6">
                                <label
                                    for="password"
                                    class="block text-zinc-300 text-sm font-medium mb-2"
                                >
                                    Password
                                </label>
                                <input
                                    type="password"
                                    id="password"
                                    name="password"
                                    required
                                    autofocus
                                    class="w-full px-4 py-2 bg-zinc-800 border border-zinc-700 rounded-lg text-zinc-100 focus:outline-none focus:ring-2 focus:ring-zinc-600 focus:border-transparent"
                                />
                            </div>
                            <button
                                type="submit"
                                class="w-full px-4 py-2 bg-zinc-700 hover:bg-zinc-600 text-zinc-100 rounded-lg font-medium transition-colors"
                            >
                                Login
                            </button>
                        </form>
                        {Astro.request.method === "POST" && (
                            <p class="mt-4 text-red-400 text-sm text-center">
                                Invalid password
                            </p>
                        )}
                    </div>
                </div>
            ) : (
                <div class="p-8">
                    <header class="mb-8 flex justify-between items-start">
                        <div>
                            <h1
                                class="text-red-50 text-3xl md:text-4xl font-bold mb-4"
                                style="font-family: 'Poppins', sans-serif;"
                            >
                                Admin Dashboard
                            </h1>
                            {photo && (
                                <p class="text-zinc-400 text-sm">
                                    Photo <span
                                        id="photo-id-display"
                                        class="underline decoration-dotted cursor-pointer hover:text-zinc-200 transition-colors"
                                        title="Click to jump to ID"
                                    >{photo.id}</span> / {maxImageId}
                                    <input
                                        id="photo-id-input"
                                        type="number"
                                        min="1"
                                        max={maxImageId}
                                        class="hidden w-16 bg-zinc-800 border border-zinc-600 rounded px-1 text-zinc-100 text-sm focus:outline-none focus:border-zinc-400"
                                    />
                                </p>
                            )}
                        </div>
                        <div class="flex gap-4">
                            <a
                                href="/"
                                class="px-4 py-2 bg-zinc-800 hover:bg-zinc-700 text-zinc-100 rounded-lg text-sm transition-colors"
                            >
                                View Site
                            </a>
                            <form method="POST" action="/admin/logout">
                                <button
                                    type="submit"
                                    class="px-4 py-2 bg-zinc-800 hover:bg-zinc-700 text-zinc-100 rounded-lg text-sm transition-colors"
                                >
                                    Logout
                                </button>
                            </form>
                        </div>
                    </header>

                    {error && (
                        <div class="bg-red-900/20 border border-red-800 text-red-300 px-4 py-3 rounded-lg mb-8">
                            Error: {error}
                        </div>
                    )}

                    {photo && (
                        <div>
                            {/* Navigation */}
                            <div class="flex gap-4 mb-8">
                                <a
                                    href={`/admin?id=${Math.max(1, photo.id - 1)}`}
                                    class={`px-6 py-2 rounded-lg text-sm transition-colors ${
                                        photo.id === 1
                                            ? "bg-zinc-900 text-zinc-600 cursor-not-allowed"
                                            : "bg-zinc-800 hover:bg-zinc-700 text-zinc-100"
                                    }`}
                                    aria-disabled={photo.id === 1}
                                >
                                    ← Previous
                                </a>
                                <a
                                    href={`/admin?id=${Math.min(maxImageId, photo.id + 1)}`}
                                    class={`px-6 py-2 rounded-lg text-sm transition-colors ${
                                        photo.id === maxImageId
                                            ? "bg-zinc-900 text-zinc-600 cursor-not-allowed"
                                            : "bg-zinc-800 hover:bg-zinc-700 text-zinc-100"
                                    }`}
                                    aria-disabled={photo.id === maxImageId}
                                >
                                    Next →
                                </a>
                            </div>

                            {/* Photo and Data Grid */}
                            <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
                                {/* Photo Preview */}
                                <div class="bg-zinc-900 rounded-lg p-4">
                                    <img
                                        src={`${imageBaseURL}/${photo.basename}_960w.jpg`}
                                        alt={photo.description || `Photo ${photo.id}`}
                                        class="w-full h-auto rounded"
                                        style={`transform: rotate(${(photo.rotation || 0) * 90}deg);`}
                                    />
                                </div>

                                {/* Photo Data Table */}
                                <div class="bg-zinc-900 rounded-lg p-6">
                                    <h2 class="text-zinc-100 text-xl font-semibold mb-4" style="font-family: 'Poppins', sans-serif;">
                                        Photo Data
                                    </h2>
                                    <table class="w-full text-sm">
                                        <tbody class="divide-y divide-zinc-800">
                                            <tr>
                                                <td class="py-3 text-zinc-400 font-medium">ID</td>
                                                <td class="py-3 text-zinc-100">{photo.id}</td>
                                            </tr>
                                            <tr>
                                                <td class="py-3 text-zinc-400 font-medium">Basename</td>
                                                <td class="py-3 text-zinc-100 font-mono text-xs">{photo.basename}</td>
                                            </tr>
                                            <tr>
                                                <td class="py-3 text-zinc-400 font-medium">Original Ref</td>
                                                <td class="py-3 text-zinc-100 font-mono text-xs">{photo.originalRef || "—"}</td>
                                            </tr>
                                            <tr>
                                                <td class="py-3 text-zinc-400 font-medium">Dimensions</td>
                                                <td class="py-3 text-zinc-100">{photo.width} × {photo.height}</td>
                                            </tr>
                                            <tr>
                                                <td class="py-3 text-zinc-400 font-medium">Available Sizes</td>
                                                <td class="py-3 text-zinc-100 font-mono text-xs">{parseSizes(photo.availableSizes).join(", ")}</td>
                                            </tr>
                                            <tr>
                                                <td class="py-3 text-zinc-400 font-medium">Date</td>
                                                <td class="py-3 text-zinc-100 font-mono">{formatAdminDate(photo)}</td>
                                            </tr>
                                            <tr>
                                                <td class="py-3 text-zinc-400 font-medium">Sequence</td>
                                                <td class="py-3 text-zinc-100">{photo.sequence ?? "—"}</td>
                                            </tr>
                                            <tr>
                                                <td class="py-3 text-zinc-400 font-medium">Sequence Raw</td>
                                                <td class="py-3 text-zinc-100 font-mono text-xs">{photo.sequenceRaw || "—"}</td>
                                            </tr>
                                            <tr>
                                                <td class="py-3 text-zinc-400 font-medium">Rotation</td>
                                                <td class="py-3 text-zinc-100">
                                                    {photo.rotation ?? 0} ({(photo.rotation || 0) * 90}°)
                                                </td>
                                            </tr>
                                            <tr>
                                                <td class="py-3 text-zinc-400 font-medium">Hidden</td>
                                                <td class="py-3 text-zinc-100">{photo.hidden ? "Yes" : "No"}</td>
                                            </tr>
                                            <tr>
                                                <td class="py-3 text-zinc-400 font-medium">Description</td>
                                                <td class="py-3 text-zinc-100">{photo.description || "—"}</td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    )}
                </div>
            )
        }
        <script is:inline define:vars={{ maxImageId }}>
            const display = document.getElementById('photo-id-display');
            const input = document.getElementById('photo-id-input');

            if (display && input) {
                display.addEventListener('click', () => {
                    input.value = display.textContent.trim();
                    display.classList.add('hidden');
                    input.classList.remove('hidden');
                    input.focus();
                    input.select();
                });

                const commit = () => {
                    const val = parseInt(input.value, 10);
                    if (!isNaN(val) && val >= 1 && val <= maxImageId) {
                        window.location.href = `/admin?id=${val}`;
                    } else {
                        cancel();
                    }
                };

                const cancel = () => {
                    input.classList.add('hidden');
                    display.classList.remove('hidden');
                };

                input.addEventListener('keydown', (e) => {
                    if (e.key === 'Enter') commit();
                    if (e.key === 'Escape') cancel();
                });

                input.addEventListener('blur', cancel);
            }
        </script>
    </body>
</html>
